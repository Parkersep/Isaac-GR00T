# Exclude large/unnecessary files from the Docker build context.
# The build context is docker/, and build.sh copies the repo into docker/src/gr00t/.
# These patterns filter out junk that gets copied in.

src/gr00t/.venv/
src/gr00t/.git/
src/gr00t/.pytest_cache/
src/gr00t/.mypy_cache/
src/gr00t/.ruff_cache/
src/gr00t/logs/
src/gr00t/dist/
src/gr00t/docker/src/
src/gr00t/gr00t_n1d7_onnx/
src/gr00t/gr00tmetricbenchmarks/
**/__pycache__/
**/*.pyc
**/*.egg-info/

# Non-base-repo files
src/gr00t/Notes/
src/gr00t/wandb/
src/gr00t/external_dependencies/
src/gr00t/uv.lock
src/gr00t/*.egg-info/
